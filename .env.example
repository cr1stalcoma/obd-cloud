# Copy to .env on VPS — never commit real values

# Telegram (rotate if token was exposed in chat)
TELEGRAM_BOT_TOKEN=

# Random secrets — generate: openssl rand -hex 32
BOT_INTERNAL_TOKEN=
POSTGRES_PASSWORD=
ENCRYPTION_KEY=

# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

POSTGRES_USER=obd
POSTGRES_DB=obd_cloud

# Public API URL (for bridge on PC)
PUBLIC_API_URL=https://obd.lexora.by

# PC bridge (local .env.bridge)
SCANNER_ID=565300
SCANNER_SECRET=
COM_PORT=COM3
